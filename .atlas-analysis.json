  "keyFeatures": [
    "IssueOps-based lock/unlock via PR comments (.lock, .unlock)",
    "Headless mode for programmatic lock/unlock via workflow dispatch",
    "Multi-environment support with per-environment locks",
    "Global lock that blocks all environments simultaneously",
    "Lock status check mode with rich output variables",
    "Sticky locks that persist until explicitly released",
    "Reaction-based acknowledgement on PR comments",
    "Automatic permission validation (admin/write required)"
  ],
